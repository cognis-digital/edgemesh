# systemd unit for the edgemesh gateway (Linux edge nodes / servers).
# Install:
#   sudo cp deploy/edgemesh.service /etc/systemd/system/
#   sudo systemctl daemon-reload && sudo systemctl enable --now edgemesh
[Unit]
Description=edgemesh gateway (unified OpenAI-compatible mesh)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
# Adjust User and the edgemesh path for your install (pipx: ~/.local/bin/edgemesh).
User=%i
ExecStart=/usr/local/bin/edgemesh serve --host 0.0.0.0 --port 8780
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target
